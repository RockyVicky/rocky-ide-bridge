# =========================================================================
# Rocky Backend Environment Template
# Rename this file to .env and fill in your keys. Do NOT commit your actual .env file.
# =========================================================================

# Port for Rocky Express & Socket.io server
PORT=3001

# -------------------------------------------------------------------------
# LLM Providers & API Keys
# -------------------------------------------------------------------------

# Gemini API Key (Required for voice transcription via Gemini 2.5 Flash)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (Optional: for routing to various open-source models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API Key (Optional: for GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# NVIDIA API Key (Optional: for NVIDIA NIM endpoints)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Priority order of models to try for execution/routing
MODEL_PRIORITY=gpt-4o,gemini-2.5-pro,gemini-2.5-flash,qwen2.5-coder:7b

# -------------------------------------------------------------------------
# Telegram Bot Configuration
# -------------------------------------------------------------------------

# Bot Token from BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (Security constraint: only messages from this ID are accepted)
TELEGRAM_USER_ID=your_numerical_telegram_user_id_here

# Custom Telegram API Root (Highly recommended for users in India or other regions
# where api.telegram.org is blocked/throttled. Set up a Cloudflare Worker as a proxy 
# and input the Worker URL here. e.g., https://your-worker.yourname.workers.dev)
TELEGRAM_API_ROOT=https://api.telegram.org

# -------------------------------------------------------------------------
# CrewAI / Agent Orchestration Configuration (Optional)
# -------------------------------------------------------------------------
CREWAI_ENABLED=false
CREWAI_STRATEGIST_MODEL=gemini-1.5-flash
CREWAI_RESEARCHER_MODEL=gemini-1.5-flash
CREWAI_MAX_RPM=10
CREWAI_AGENT_MAX_ITER=3
CREWAI_ENABLE_CACHE=true

# -------------------------------------------------------------------------
# Tunnel & Network Settings
# -------------------------------------------------------------------------
# NGROK Auth Token (Optional: if you want a high-stability Ngrok tunnel, 
# otherwise Rocky falls back to Localtunnel automatically)
# NGROK_AUTHTOKEN=your_ngrok_authtoken_here

TUNNEL_RETRY_DELAY_MS=15000
TUNNEL_MAX_ATTEMPTS=0
TUNNEL_CONNECT_TIMEOUT_MS=12000
STALE_EXECUTION_MINUTES=30
